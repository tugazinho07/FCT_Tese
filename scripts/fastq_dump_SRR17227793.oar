#!/bin/bash
set -euo pipefail

echo "HOST: $(hostname)"
echo "START: $(date)"
echo "PWD (before cd): $(pwd)"

# Ir para o diretório onde está o SRA_Tool
cd /home/ga.soares/SRA_Tool

echo "PWD (after cd): $(pwd)"

# Executar fastq-dump
/home/ga.soares/SRA_Tool/sratoolkit.3.2.1-alma_linux64/bin/fastq-dump \
  --split-files \
  SRR17227787

echo "END: $(date)"
